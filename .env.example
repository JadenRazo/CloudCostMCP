# CloudCost MCP Server Configuration
# All settings are optional - the server works with zero configuration

# Cache TTL in seconds (default: 86400 = 24 hours)
# CLOUDCOST_CACHE_TTL=86400

# Cache database path (default: ~/.cloudcost/cache.db)
# CLOUDCOST_CACHE_PATH=

# Log level: debug, info, warn, error (default: info)
# CLOUDCOST_LOG_LEVEL=info

# Monthly hours assumption for cost calculations (default: 730)
# CLOUDCOST_MONTHLY_HOURS=730
