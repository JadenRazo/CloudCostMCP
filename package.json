{
  "name": "@jadenrazo/cloudcost-mcp",
  "version": "1.0.1",
  "description": "MCP server for multi-cloud cost analysis of Terraform, CloudFormation, Pulumi, and Bicep/ARM codebases",
  "type": "module",
  "license": "MIT",
  "author": "Jaden Razo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JadenRazo/CloudCostMCP.git"
  },
  "homepage": "https://github.com/JadenRazo/CloudCostMCP#readme",
  "bugs": {
    "url": "https://github.com/JadenRazo/CloudCostMCP/issues"
  },
  "keywords": [
    "mcp",
    "terraform",
    "cloud-cost",
    "aws",
    "azure",
    "gcp",
    "cost-estimation",
    "infrastructure",
    "opentofu",
    "finops",
    "focus",
    "spot-pricing",
    "multi-currency",
    "github-actions",
    "budget",
    "what-if"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "data",
    "README.md",
    "LICENSE",
    "VERSIONING.md",
    "CHANGELOG.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cloudcost-mcp": "dist/index.js",
    "cloudcost": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "bench": "vitest bench",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && eslint src test",
    "format": "prettier --write src test",
    "format:check": "prettier --check src test",
    "check": "npm run typecheck && eslint src test && npm run format:check",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=high",
    "refresh-pricing": "tsx scripts/refresh-pricing.ts",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@cdktf/hcl2json": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "better-sqlite3": "^11.9.1",
    "yaml": "^2.8.3",
    "zod": "^3.24.4"
  },
  "overrides": {
    "hono": "^4.12.12",
    "@hono/node-server": "^1.19.13",
    "path-to-regexp": "^8.4.0",
    "vite": "^7.3.2"
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "tabWidth": 2,
    "printWidth": 100
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.1.1"
  }
}
